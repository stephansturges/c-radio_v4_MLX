+def layernorm_perchannel_linear(
+    x: mx.array,
+    norm_weight: mx.array,
+    norm_bias: mx.array,
+    w: mx.array,
+    scale_w: mx.array,
+    bias: Optional[mx.array] = None,
+    eps: float = 1e-6,
+    stream: Optional[mx.Stream] = None,
+) -> mx.array:
+    """Fused LayerNorm + W8A8 per-channel quantized linear.
+
+    Computes ``perchannel_linear(layer_norm(x, norm_weight, norm_bias), ...)``
+    with the layernorm and activation quantization fused into one Metal kernel.
+    The result should be used for prefill-style 2D inputs [M, K].
+    """
+    ext = _load_ext()
+    out_dtype = x.dtype
+    kw = {"stream": stream} if stream is not None else {}
+    N = w.shape[0]
+    if bias is None:
+        bias = mx.zeros((N,), dtype=mx.float16)
+    result = ext.layernorm_perchannel_linear(
+        x,
+        norm_weight,
+        norm_bias,
+        w,
+        scale_w,
+        bias,
+        float(eps),
+        kernel_dir(),
+        **kw,
+    )
+    if out_dtype != mx.float16:
+        result = result.astype(out_dtype, **kw)
+    return result
+
+
 # Shared placeholder for new_bias (V5 kernel ignores it; Metal needs valid buffer)
