+// ============================================================
+// Fused LayerNorm + per-token quantization: FP16 -> INT8 + scale
+// Target: Apple M5, Metal 4
+//
+// Each threadgroup handles one row. Threads reduce mean/variance,
+// apply affine LayerNorm, reduce absmax, and quantize to INT8.
+// ============================================================
+
+#include <metal_stdlib>
+using namespace metal;
+
+kernel void layernorm_quantize_per_token(
+    const device half *X [[buffer(0)]],        // [M, K] FP16 input
+    const device half *gamma [[buffer(1)]],    // [K] LayerNorm weight
+    const device half *beta [[buffer(2)]],     // [K] LayerNorm bias
+    device int8_t *A [[buffer(3)]],            // [M, K] INT8 output
+    device float *scale [[buffer(4)]],         // [M] activation scale
+    constant uint &M [[buffer(5)]],
+    constant uint &K [[buffer(6)]],
+    constant float &eps [[buffer(7)]],
+    uint gid [[threadgroup_position_in_grid]],
+    uint lid [[thread_index_in_threadgroup]],
+    uint tg_size [[threads_per_threadgroup]]) {
+  if (gid >= M) {
+    return;
+  }
+
+  const device half *row_in = X + gid * K;
+  device int8_t *row_out = A + gid * K;
+
+  uint sg_id = lid / 32;
+  uint sg_lid = lid % 32;
+  uint num_sgs = (tg_size + 31) / 32;
+
+  threadgroup float sg_sums[8];
+  threadgroup float sg_sumsq[8];
+  threadgroup float sg_maxes[8];
+  threadgroup float shared_mean;
+  threadgroup float shared_inv_std;
+  threadgroup float shared_scale;
+  threadgroup float shared_inv_scale;
+
+  float local_sum = 0.0f;
+  float local_sumsq = 0.0f;
+  for (uint i = lid; i < K; i += tg_size) {
+    float v = float(row_in[i]);
+    local_sum += v;
+    local_sumsq += v * v;
+  }
+
+  float lane_sum = simd_sum(local_sum);
+  float lane_sumsq = simd_sum(local_sumsq);
+  if (sg_lid == 0) {
+    sg_sums[sg_id] = lane_sum;
+    sg_sumsq[sg_id] = lane_sumsq;
+  }
+  threadgroup_barrier(mem_flags::mem_threadgroup);
+
+  if (sg_id == 0) {
+    float total_sum = 0.0f;
+    float total_sumsq = 0.0f;
+    if (sg_lid < num_sgs) {
+      total_sum = sg_sums[sg_lid];
+      total_sumsq = sg_sumsq[sg_lid];
+    }
+    total_sum = simd_sum(total_sum);
+    total_sumsq = simd_sum(total_sumsq);
+
+    if (sg_lid == 0) {
+      float inv_k = 1.0f / float(K);
+      float mean = total_sum * inv_k;
+      float variance = max(total_sumsq * inv_k - mean * mean, 0.0f);
+      shared_mean = mean;
+      shared_inv_std = rsqrt(variance + eps);
+    }
+  }
+  threadgroup_barrier(mem_flags::mem_threadgroup);
+
+  float mean = shared_mean;
+  float inv_std = shared_inv_std;
+
+  float local_max = 0.0f;
+  for (uint i = lid; i < K; i += tg_size) {
+    float normalized =
+        (float(row_in[i]) - mean) * inv_std * float(gamma[i]) + float(beta[i]);
+    local_max = max(local_max, abs(normalized));
+  }
+
+  float lane_max = simd_max(local_max);
+  if (sg_lid == 0) {
+    sg_maxes[sg_id] = lane_max;
+  }
+  threadgroup_barrier(mem_flags::mem_threadgroup);
+
+  if (sg_id == 0) {
+    float row_max = 0.0f;
+    if (sg_lid < num_sgs) {
+      row_max = sg_maxes[sg_lid];
+    }
+    row_max = simd_max(row_max);
+
+    if (sg_lid == 0) {
+      float s = row_max / 127.0f;
+      if (s == 0.0f) {
+        s = 1.0f;
+      }
+      shared_scale = s;
+      shared_inv_scale = 1.0f / s;
+      scale[gid] = s;
+    }
+  }
+  threadgroup_barrier(mem_flags::mem_threadgroup);
+
+  float inv_s = shared_inv_scale;
+  for (uint i = lid; i < K; i += tg_size) {
+    float normalized =
+        (float(row_in[i]) - mean) * inv_std * float(gamma[i]) + float(beta[i]);
+    float q = clamp(round(normalized * inv_s), -128.0f, 127.0f);
+    row_out[i] = int8_t(q);
+  }
+}
diff --git a/cider/ops.py b/cider/ops.py
