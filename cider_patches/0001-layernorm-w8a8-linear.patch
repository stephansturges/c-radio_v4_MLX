@@ -53,2 +53,38 @@ class W8A8Linear : public mx::Primitive {
 
+// ── Fused LayerNorm + W8A8 Linear Primitive ─────────────────────
+// Inputs:
+//   x(M,K) float16, norm_weight(K) float16, norm_bias(K) float16,
+//   w(N,K) int8, scale_w(N) float32, bias(N) float16
+// Output: [y(M,N) float16]
+//
+// Dispatches layernorm + per-token activation quantization in one Metal
+// kernel, then reuses the existing INT8 TensorOps GEMM/dequant kernel.
+class LayerNormW8A8Linear : public mx::Primitive {
+ public:
+  LayerNormW8A8Linear(mx::Stream stream, const std::string& kernel_dir, float eps)
+      : mx::Primitive(stream), kernel_dir_(kernel_dir), eps_(eps) {}
+
+  void eval_cpu(
+      const std::vector<mx::array>& inputs,
+      std::vector<mx::array>& outputs) override {
+    throw std::runtime_error("LayerNormW8A8Linear: CPU not supported");
+  }
+
+  void eval_gpu(
+      const std::vector<mx::array>& inputs,
+      std::vector<mx::array>& outputs) override;
+
+  const char* name() const override {
+    return "LayerNormW8A8Linear";
+  }
+
+  bool is_equivalent(const mx::Primitive& other) const override {
+    return true;
+  }
+
+ private:
+  std::string kernel_dir_;
+  float eps_;
+};
+
 
