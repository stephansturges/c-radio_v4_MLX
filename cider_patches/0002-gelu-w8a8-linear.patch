@@ -199,2 +199,33 @@ def layernorm_perchannel_linear(
 
+def gelu_perchannel_linear(
+    x: mx.array,
+    w: mx.array,
+    scale_w: mx.array,
+    bias: Optional[mx.array] = None,
+    stream: Optional[mx.Stream] = None,
+) -> mx.array:
+    """Fused exact GELU + W8A8 per-channel quantized linear.
+
+    Computes ``perchannel_linear(gelu_exact(x), ...)`` with GELU and activation
+    quantization fused into one Metal kernel before the existing INT8 GEMM.
+    """
+    ext = _load_ext()
+    out_dtype = x.dtype
+    kw = {"stream": stream} if stream is not None else {}
+    N = w.shape[0]
+    if bias is None:
+        bias = mx.zeros((N,), dtype=mx.float16)
+    result = ext.gelu_perchannel_linear(
+        x,
+        w,
+        scale_w,
+        bias,
+        kernel_dir(),
+        **kw,
+    )
+    if out_dtype != mx.float16:
+        result = result.astype(out_dtype, **kw)
+    return result
+
+
 # Shared placeholder for new_bias (V5 kernel ignores it; Metal needs valid buffer)
