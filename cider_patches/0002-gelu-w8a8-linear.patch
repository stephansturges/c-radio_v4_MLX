--- /dev/null
+++ b/cider/kernels/gelu_quantize.metal
@@ -0,0 +1,89 @@
+// ============================================================
+// Fused exact GELU + per-token quantization: FP16 -> INT8 + scale
+// Target: Apple M5, Metal 4
+//
+// Each threadgroup handles one row. Threads apply GELU, reduce absmax,
+// and quantize to INT8.
+// ============================================================
+
+#include <metal_stdlib>
+using namespace metal;
+
+inline float erf_approx(float x) {
+  float sign = x < 0.0f ? -1.0f : 1.0f;
+  float ax = abs(x);
+  float t = 1.0f / (1.0f + 0.3275911f * ax);
+  float y =
+      1.0f -
+      (((((1.061405429f * t - 1.453152027f) * t + 1.421413741f) * t -
+         0.284496736f) *
+            t +
+        0.254829592f) *
+       t * exp(-ax * ax));
+  return sign * y;
+}
+
+inline float gelu_exactish(float x) {
+  return 0.5f * x * (1.0f + erf_approx(x * 0.7071067811865476f));
+}
+
+kernel void gelu_quantize_per_token(
+    const device half *X [[buffer(0)]], // [M, K] FP16 input
+    device int8_t *A [[buffer(1)]],     // [M, K] INT8 output
+    device float *scale [[buffer(2)]],  // [M] activation scale
+    constant uint &M [[buffer(3)]],
+    constant uint &K [[buffer(4)]],
+    uint gid [[threadgroup_position_in_grid]],
+    uint lid [[thread_index_in_threadgroup]],
+    uint tg_size [[threads_per_threadgroup]]) {
+  if (gid >= M) {
+    return;
+  }
+
+  const device half *row_in = X + gid * K;
+  device int8_t *row_out = A + gid * K;
+
+  uint sg_id = lid / 32;
+  uint sg_lid = lid % 32;
+  uint num_sgs = (tg_size + 31) / 32;
+
+  threadgroup float sg_maxes[8];
+  threadgroup float shared_scale;
+  threadgroup float shared_inv_scale;
+
+  float local_max = 0.0f;
+  for (uint i = lid; i < K; i += tg_size) {
+    local_max = max(local_max, abs(gelu_exactish(float(row_in[i]))));
+  }
+
+  float lane_max = simd_max(local_max);
+  if (sg_lid == 0) {
+    sg_maxes[sg_id] = lane_max;
+  }
+  threadgroup_barrier(mem_flags::mem_threadgroup);
+
+  if (sg_id == 0) {
+    float row_max = 0.0f;
+    if (sg_lid < num_sgs) {
+      row_max = sg_maxes[sg_lid];
+    }
+    row_max = simd_max(row_max);
+
+    if (sg_lid == 0) {
+      float s = row_max / 127.0f;
+      if (s == 0.0f) {
+        s = 1.0f;
+      }
+      shared_scale = s;
+      shared_inv_scale = 1.0f / s;
+      scale[gid] = s;
+    }
+  }
+  threadgroup_barrier(mem_flags::mem_threadgroup);
+
+  float inv_s = shared_inv_scale;
+  for (uint i = lid; i < K; i += tg_size) {
+    float q = clamp(round(gelu_exactish(float(row_in[i])) * inv_s), -128.0f, 127.0f);
+    row_out[i] = int8_t(q);
+  }
+}
